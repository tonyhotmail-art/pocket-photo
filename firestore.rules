rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // 輔助函式 (共用)
    // =============================================

    // 檢查是否為系統層級的授權 Email（Tony / Kelly 擁有上帝權限）
    function isAuthorizedEmail() {
      return request.auth != null &&
             (request.auth.token.email == 'tony.hotmail@gmail.com' ||
              request.auth.token.email == 'kellykelly555888@gmail.com' ||
              request.auth.token.email == 'tony7777777@gmail.com');
    }

    // 檢查是否為特定租戶的管理員
    function isTenantAdmin(tenantId) {
      return isAuthorizedEmail() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.tenantId == tenantId
      );
    }

    // 判斷是否有任何有效登入身分
    function isAuthenticated() {
      return request.auth != null;
    }

    // =============================================
    // Portfolio 相簿系統集合
    // =============================================

    // 作品照片集合
    match /portfolio_items/{itemId} {
      // 只有管理員可以讀取「待分類照片」；其它照片公開
      allow read: if isAuthorizedEmail() || resource.data.categoryName != '待分類照片' || isTenantAdmin(resource.data.tenantId);
      // 只有管理員可以建立、更新、刪除
      allow create, update, delete: if isAuthorizedEmail() || (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
    }

    // 分類集合
    match /categories/{categoryId} {
      allow read: if isAuthorizedEmail() || resource.data.name != '待分類照片' || isTenantAdmin(resource.data.tenantId);
      allow create, update, delete: if isAuthorizedEmail() || (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
    }

    // 管理員名單集合
    match /admins/{adminId} {
      allow read: if isAuthorizedEmail() || (request.auth != null && resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
      allow create, update, delete: if isAuthorizedEmail();
    }

    // 租戶資訊 (公開店鋪資訊)
    match /tenants/{tenantDocId} {
      allow read: if true;
      allow write: if isAuthorizedEmail();
    }

    // =============================================
    // 預設規則：禁止所有其他未明確定義的集合
    // =============================================
    match /{document=**} {
      allow read, write: if isAuthorizedEmail();
    }
  }
}
